# BASE L2 CONFIGURATION
# Best for detecting memecoin accumulation and fast retail sweeps

WHALE_THRESHOLD_USD=10000
LITE_MODE=true
GETBLOCK_BASE_RPC=https://mainnet.base.org
# Using fast-sync polling for L2 without WebSocket
WS_PORT=3001

# Memory config for Lite Mode
NEO4J_MAX_MEMORY=1G
PRISMA_GENERATE_DATAPROXY=true
