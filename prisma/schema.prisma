// schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // NOTE: pg_trgm/btree_gin/unaccent extensions omitted —
  // Railway PostgreSQL does not guarantee superuser extension access.
  // Full-text search is handled at the application layer via Prisma fullTextSearchPostgres.
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

// ─────────────────────────────────────────────────────────────────────────────
// TRI-LAYER KINETIC MATRICES & ARTICLES
// ─────────────────────────────────────────────────────────────────────────────

model Article {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  sentiment   Float    // AI Score 0-100 indicating sentiment
  bias        String   // "Bullish", "Bearish", "Neutral"
  category    String   // "Macro", "Regulation", "DeFi", "Hacks"
  publishedAt DateTime @default(now())
  sectorId    String?
  author      String

  sector      Sector?  @relation(fields: [sectorId], references: [id])

  // ── 🔍 INDEXACIÓN CÓSMICA: Articulación para texto completo e informes temporales
  @@index([category, publishedAt(sort: Desc)])  // Filtrado rápido por categoría + cronología
  @@index([bias, sentiment])                    // Análisis de polaridad institucional
  @@index([sectorId, publishedAt(sort: Desc)])  // Drill-down por sector en dashboards
}

// ─────────────────────────────────────────────────────────────────────────────
// 103 MICRO-SECTORS ENGINE
// ─────────────────────────────────────────────────────────────────────────────

model Sector {
  id          String    @id @default(uuid())
  slug        String    @unique // e.g. "layer-1", "ai", "rwa", "yield-farming"
  name        String
  description String?   @db.Text
  totalTvl    Float     @default(0.0)
  volume24h   Float     @default(0.0)
  zScore      Float     // Custom Whale Rotation Score
  articles    Article[]

  // ── 🔍 INDEXACIÓN CÓSMICA: Rendimiento y ordenamiento dinámico
  @@index([zScore(sort: Desc)])   // Top Sectors by Whale Rotation Score
  @@index([totalTvl(sort: Desc)]) // Ranking por TVL en tiempo real
}

// ─────────────────────────────────────────────────────────────────────────────
// SOVEREIGN AUTHORITY & COMMERCIAL ONTOLOGY
// ─────────────────────────────────────────────────────────────────────────────

model GoldRegistryAudit {
  id                 String   @id @default(uuid())
  platformName       String
  slug               String   @unique
  type               String   // "Casino", "Wallet", "Exchange", "PredictionMarket"
  isVerifiedOnChain  Boolean  @default(false)
  smartContractRef   String?  // Contract validated by local/Polygon ping
  solvencyStatus     String   // "Confirmed", "Suspicious", "Unknown"
  sovereignBridgeUrl String   // E.g., The dark-pool routed affiliate bridge
  
  // High-performance metrics tailored to CryptoSlate's taxonomies
  features           String[] // ["No KYC", "Instant Withdrawal", "Cold Storage"]
  supportedChains    String[] // ["Ethereum", "Solana", "Base"]
}

// ─────────────────────────────────────────────────────────────────────────────
// ECOSYSTEM MAPPING
// ─────────────────────────────────────────────────────────────────────────────

model EcosystemWarRoomData {
  id          String   @id @default(uuid())
  chainName   String   @unique
  chainSymbol String
  totalEntities Int    @default(0)
  tvl         Float    @default(0.0)
  volume24h   Float    @default(0.0)
}

// ─────────────────────────────────────────────────────────────────────────────
// SOVEREIGN USER PROFILES & WATCHLISTS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String      @id @default(uuid())
  walletAddress   String      @unique
  isPro           Boolean     @default(false)
  tier            String      @default("basic")
  lastActive      DateTime    @default(now())
  goldTicketTokenId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  worldIdNullifierHash String? @unique
  
  theme           String      @default("light")
  currency        String      @default("USD")
  language        String      @default("es-ES")

  showBalances    Boolean     @default(true)
  hiddenAssets    String[]    @default([])
  defaultTimeframe String     @default("1W") // "1D", "1W", "1M", "ALL"
  displayUnit     String      @default("FIAT") // "FIAT", "BTC", "ETH"

  gasPreset       String      @default("STANDARD") // "ECONOMY", "STANDARD", "FAST", "INSTANT"
  customRpcUrl    String?     
  mevProtection   Boolean     @default(false)
  maxSlippage     Float       @default(0.5)

  inactivityLockMinutes Int   @default(60)
  stealthMode     Boolean     @default(false)
  requireSignForExports Boolean @default(true)
  allowAnalytics  Boolean     @default(true)

  emailAlerts     Boolean     @default(false)
  telegramAlerts  Boolean     @default(false)
  whaleAlertThreshold Float   @default(1000000)
  soundEffects    Boolean     @default(true)

  testnetMode     Boolean     @default(false)
  
  clerkId         String?     @unique
  snxAccountId    String?     @unique
  
  watchlists      Watchlist[]
  alerts          Alert[]
  canvasState     CanvasState?
  progress        UserProgress[]
  submissions     AcademySubmission[]
  sentMessages    MentoringMessage[] @relation("SentMessages")
  receivedMessages MentoringMessage[] @relation("ReceivedMessages")

  // Forum Relations
  forumTopics     ForumTopic[]
  forumPosts      ForumPost[]
  forumLikes      ForumLike[]
  forumNotifications ForumNotification[]
  actorNotifications ForumNotification[] @relation("ActorNotifications")

  // ── 🔍 INDEXACIÓN CÓSMICA: Segmentación de usuarios para analytics y acceso a nivel Pro
  @@index([tier, lastActive(sort: Desc)])  // Consulta de usuarios activos por tier
  @@index([isPro, createdAt(sort: Desc)])  // Funnel de conversión Pro
  @@index([createdAt(sort: Desc)])         // Registro cronológico general
}

// ─────────────────────────────────────────────────────────────────────────────
// SAAS SUBSCRIPTIONS & STRIPE
// FIX: Missing Subscription model referenced by Stripe webhooks
// ─────────────────────────────────────────────────────────────────────────────
model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique // Maps to User.walletAddress typically
  status    String   // 'ACTIVE', 'CANCELED', 'PAST_DUE'
  tier      String   // 'LIFETIME_VIP', 'PRO_MONTHLY', etc.
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Watchlist {
  id          String   @id @default(uuid())
  userId      String
  symbol      String   // E.g., "BTCUSDT" or a contract address
  chain       String   @default("multi")
  addedAt     DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, chain])
}

model Alert {
  id          String   @id @default(uuid())
  userId      String
  targetType  String   // "PRICE", "GAS", "WHALE_TX", "LIQUIDATION"
  condition   String   // "ABOVE", "BELOW", "EQUALS"
  threshold   Float
  metric      String   // e.g., "BTC", "ETH_GAS"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CanvasState {
  id          String   @id @default(uuid())
  userId      String   @unique
  nodes       Json     // Institutional Node Topography
  edges       Json     // Connection Matrices
  pan         Json?    // Navigation Coordinates
  lastSyncedAt DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// SIWE AUTHENTICATION NONCES
// ─────────────────────────────────────────────────────────────────────────────

model SiweNonce {
  id        String   @id @default(uuid())
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// ON-CHAIN ACADEMY PROGRESSION
// ─────────────────────────────────────────────────────────────────────────────

model Course {
  id            String   @id @default(uuid())
  slug          String   @unique
  title         String
  description   String   @db.Text
  totalDuration String
  badge         String?
  level         String   @default("Beginner")
  lessons       Lesson[]
}

model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  duration    String
  level       String
  description String   @db.Text
  orderIndex  Int
  isLocked    Boolean  @default(false)
  
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    UserProgress[]
  submissions AcademySubmission[]
}

model UserProgress {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  completed Boolean  @default(true)
  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ACADEMY MENTORING & TEACHER VALIDATIONS (MAXIMUM LMS)
// ─────────────────────────────────────────────────────────────────────────────

model AcademySubmission {
  id          String   @id @default(uuid())
  userId      String   
  lessonId    String
  contentUrl  String?
  txHash      String?  
  status      String   @default("PENDING") // PENDING, PASSED, FAILED
  feedback    String?  @db.Text
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([status])
}

model MentoringMessage {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  content     String   @db.Text
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, read])
}

// ─────────────────────────────────────────────────────────────────────────────
// GOLDEN TICKET CLAIM
// ─────────────────────────────────────────────────────────────────────────────

model GoldenTicket {
  id                    String   @id @default(uuid())
  userAddress           String   @unique
  serialCode            String   @unique
  tier                  String   @default("GENESIS")
  badgeColor            String   @default("GOLD")
  networkLaunchEligible Boolean  @default(true)
  ticketNumber          Int      @default(autoincrement())
  twitterHandle         String?
  signatureData         String?  @db.Text
  isActive              Boolean  @default(true)
  claimedAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt @default(now())

  // Compound indexes for dashboard query patterns:
  // /api/golden-ticket GET: WHERE isActive=true ORDER BY claimedAt DESC TAKE 30
  // /api/akashic hash verification: WHERE userAddress
  @@index([isActive, claimedAt(sort: Desc)])
  @@index([tier, claimedAt(sort: Desc)])
  @@index([ticketNumber])
}

// ─────────────────────────────────────────────────────────────────────────────
// SOVEREIGN INTELLIGENCE CORPUS (ARKHAM/NANSEN KILLER)
// ─────────────────────────────────────────────────────────────────────────────

model IntelItem {
  id          String   @id @default(uuid())
  url         String   @unique
  title       String
  source      String
  aiSummary   String?  @db.Text
  category    String   @default("FINANCE")
  priority    String   @default("SOVEREIGN")
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
}

model NewsArticle {
  id               String   @id @default(uuid())
  externalId       String?  @unique
  title            String
  summary          String   @db.Text
  url              String   @unique
  source           String
  imageUrl         String?
  category         String   @default("crypto")
  publishedAt      DateTime @default(now())
  
  // Forensic Analysis
  veracityScore    Int      @default(0)
  veracityAnalysis String?  @db.Text
  isFake           Boolean  @default(false)
  sentiment        String   @default("neutral") // bullish, bearish, neutral
  
  tokens           String[] @default([]) // Referenced in UI
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
  @@index([source])
}

model OnChainEntity {
  id              String   @id @default(uuid())
  address         String   @unique
  label           String?  // The identity of the entity
  category        String?  // Exchange, Whale, MEV, Fund
  isZkShielded    Boolean  @default(false)
  neo4jNodeId     String?  @unique // Reference to local graph DB node
  totalVolumeUSD  Float    @default(0.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastActive      DateTime @default(now())
  
  labels          EntityLabel[]
}

model EntityLabel {
  id              String   @id @default(uuid())
  entityId        String
  labelName       String
  confidenceScore Float    @default(1.0)
  source          String   // "NeuralAgent", "UserDefined", "TeranodeStream"
  createdAt       DateTime @default(now())
  
  entity          OnChainEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

model NeuralAgentConfig {
  id                  String   @id @default(uuid())
  agentId             String   @unique
  mode                String   @default("OBSERVER") // OBSERVER, EXECUTION, HFT
  maxSlippage         Float    @default(0.5)
  targetChains        String[] // E.g., ["Ethereum", "Solana", "EVM"]
  isActive            Boolean  @default(true)
  autoTradeThreshold  Float?
  lastPingAt          DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// SOBERANIA DE CUSTODIA (ON-CHAIN CONTRACT STATES)
// ─────────────────────────────────────────────────────────────────────────────

model TimeLockVault {
  id          String   @id @default(uuid())
  userAddress String   @unique
  amount      Float
  unlockDate  DateTime
  txHash      String?
  status      String   @default("LOCKED") // "LOCKED", "WITHDRAWN"
  createdAt   DateTime @default(now())
}

model DeadMansSwitch {
  id               String   @id @default(uuid())
  userAddress      String   @unique
  beneficiary      String
  inactivityPeriod Int      // En segundos
  lastPing         DateTime @default(now())
  active           Boolean  @default(true)
  txHash           String?
}

model Guardian {
  id              String   @id @default(uuid())
  userEmail       String
  guardianAddress String
  threshold       Int      @default(3) // Firmas requeridas
  isActive        Boolean  @default(true)
  
  @@unique([userEmail, guardianAddress])
}

model PrivacyDonation {
  id          String   @id @default(uuid())
  amount      Float
  nullifier   String   @unique
  commitment  String   @unique
  timestamp   DateTime @default(now())
}


// ─────────────────────────────────────────────────────────────────────────────
// WHALE TELEMETRY & ACTIVITY
// ─────────────────────────────────────────────────────────────────────────────

model WhaleActivity {
  id              String   @id @default(uuid())
  immutableId     String?  @unique(map: "sov_whale_identity_idx_v3") // Reconciliación institucional de índice
  walletAddress   String?                        // Opcional para BTC (usar toAddress)
  type            String   @default("TRANSFER")  // 'TRANSFER', 'SWAP', 'MINT', 'BURN'
  token           String   @default("BTC")
  amount          String   @default("0")
  usdValue        String   @default("0")
  valueBTC        Float    @default(0)           // Valor real en satoshis/btc
  btcPriceAtTx    Float    @default(0)           // Precio histórico capturado
  fromAddress     String
  toAddress       String
  transactionHash String   @unique
  blockNumber     BigInt?
  blockHeight     Int?                           // Altura del bloque BTC
  chain           String   @default("BTC")
  entityName      String   @default("Unknown")    // MicroStrategy, BlackRock, etc.
  institutional   Boolean  @default(false)
  confirmed       Boolean  @default(true)
  metadata        Json?
  timestamp       DateTime @default(now())
  isZkVerified    Boolean  @default(false)

  // ── 🔍 INDEXACIÓN INSTITUCIONAL
  @@index([usdValue])
  @@index([valueBTC])
  @@index([timestamp(sort: Desc)])
  @@index([institutional])
  @@index([entityName])
  @@index([chain, timestamp(sort: Desc)])

  // ── 🔍 INDEXACIÓN COMPUESTA (query patterns de /api/akashic y /api/institutional)
  // Pattern 1: Akashic feed — filtrar por chain, ordenar por timestamp, paginar
  @@index([chain, timestamp(sort: Desc), usdValue])
  // Pattern 2: Dashboard institucional — movimientos >$1M clasificados como institucionales
  @@index([institutional, usdValue, timestamp(sort: Desc)])
  // Pattern 3: Análisis por token — ej. todos los movimientos de USDC en Ethereum
  @@index([token, chain, timestamp(sort: Desc)])
  // Pattern 4: Búsqueda por dirección (from/to wallet lookup)
  @@index([fromAddress, timestamp(sort: Desc)])
  @@index([toAddress, timestamp(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// BITCOIN SV (BSV) BRC STANDARDS INDEX
// ─────────────────────────────────────────────────────────────────────────────

model BRCStandard {
  id              String   @id @default(uuid())
  brcNumber       Int      @unique
  title           String
  author          String   @default("Unknown")
  status          String   @default("Draft")
  type            String   @default("Standard")
  created         DateTime?
  updated         DateTime?
  summary         String?  @db.Text
  content         String?  @db.Text
  githubUrl       String?
  lastSyncAt      DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// EMAIL SUBSCRIBERS
// Referenced by: /api/newsletter/subscribe, /api/alerts/subscribe,
// /api/subscribe, /api/cron/supply-alerts, /api/admin/emails
// FIX: This model was MISSING from schema.prisma, causing Prisma P1009 runtime
// crashes on every newsletter subscription operation in production.
// ─────────────────────────────────────────────────────────────────────────────

model EmailSubscriber {
  id               String   @id @default(uuid())
  email            String   @unique
  frequency        String   @default("weekly") // "daily", "weekly", "monthly"
  subscribed       Boolean  @default(true)
  unsubscribeToken String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([subscribed])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// TELEGRAM ALERTS
// Referenced by: /api/telegram/connect, /api/cron/*, webhook handlers
// FIX: This model was MISSING from schema.prisma, causing Prisma P1009 runtime
// crashes every time a user attempted to configure Telegram alerts.
// ─────────────────────────────────────────────────────────────────────────────

model TelegramAlert {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  chatId        String
  minApy        Float    @default(20)
  evSignals     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([walletAddress])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPATIBILITY POLYFILLS FOR EXTENDED API ROUTES (FIX BUILD CRASHES)
// These models satisfy TS and Prisma Client generated types for legacy or 
// parallel API routes that query these models.
// ─────────────────────────────────────────────────────────────────────────────

model AuthUser {
  id              String   @id @default(uuid())
  email           String   @unique
  walletAddress   String?  @unique
  recoveryEmail   String?
  encryptedPrivateKey String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  securityEvents  SecurityEvent[]
}

model SecurityEvent {
  id              String   @id @default(uuid())
  authUserId      String?
  type            String
  severity        String   @default("INFO")
  details         String?  @db.Text
  ipAddress       String?
  userAgent       String?
  location        String?
  timestamp       DateTime @default(now())

  authUser        AuthUser? @relation(fields: [authUserId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String   @id @default(uuid())
  txHash          String   @unique
  status          String   @default("PENDING")
  type            String   // SEND, RECEIVE, REBALANCE
  amount          Float
  token           String
  fromAddress     String
  toAddress       String
  timestamp       DateTime @default(now())
  authUserId      String?

  chainId         Int      @default(1)
  value           String?
  tokenSymbol     String?
  blockNumber     BigInt?  @default(0)
  gasUsed         BigInt?  @default(0)
  metadata        Json?    @default("{}")

  @@index([authUserId])
}

model SocialRecovery {
  id              String   @id @default(uuid())
  userEmail       String   @unique
  threshold       Int      @default(3)
  delayHours      Int      @default(48)
  active          Boolean  @default(true)
}

model AIRebalancerPlan {
  id              String   @id @default(uuid())
  userId          String
  strategy        String
  payload         Json
  executed        Boolean  @default(false)
  executedAt      DateTime?
  txHashes        String[]
  expectedPnl     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GlobalWhaleEvent {
  id              String   @id @default(uuid())
  txHash          String   @unique
  amountUSD       Float
  protocol        String
  timestamp       DateTime @default(now())

  // ── 🔍 INDEXACIÓN CÓSMICA: Eventos Macro para pantalla de liderazgo institucional
  @@index([protocol, timestamp(sort: Desc)])  // Filtrado por protocolo en tiempo real
  @@index([amountUSD(sort: Desc)])            // Ranking de mayores transacciones
  @@index([timestamp(sort: Desc)])            // Vista cronológica global
}

model AlertRule {
  id              String   @id @default(uuid())
  userId          String
  condition       String
  threshold       Float
  isActive        Boolean  @default(true)
}

model WatchedWallet {
  id              String   @id @default(uuid())
  userId          String
  address         String   // Normalized: 0x... or bc1... or SOL pubkey
  label           String   @default("Anonymous Whale")
  tags            String[] @default([])
  lastValue       Float    @default(0)
  change24h       Float    @default(0)
  pnl24h          Float    @default(0)
  txCount         Int      @default(0)
  riskScore       Float    @default(50)
  activityScore   Float    @default(0)
  isWhale         Boolean  @default(false)
  isSmart         Boolean  @default(false)
  alertsEnabled   Boolean  @default(false)
  metadata        Json?    // Stats breakdown cache
  forensics       Json?    // Forensic analysis result
  category        String?  // Exchange|Whale|MEV|Fund etc.
  identityTier    String?  // LEGENDARY|ELITE|SOVEREIGN etc.
  lastCheck       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, address])
  @@index([userId, createdAt(sort: Desc)])
  @@index([address])
}

// ─────────────────────────────────────────────────────────────────────────────
// OPERATIONAL AUDIT TRAIL (sovereign action log)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   // WATCH_WALLET_ADDED | WATCH_WALLET_DELETED | SETTINGS_UPDATED etc.
  resource  String?  // Table/resource name
  metadata  Json?
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([userId, timestamp(sort: Desc)])
  @@index([action, timestamp(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// STRIPE PURCHASE INTENT (anti-chargeback evidence)
// ─────────────────────────────────────────────────────────────────────────────

model ApiPurchaseIntent {
  id              String   @id @default(uuid())
  userId          String   // Sovereign wallet address (SIWE identity)
  planId          String
  stripeSessionId String   @unique
  ip              String?
  country         String?
  userAgent       String?  @db.Text
  isSuspiciousIp  Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model KYCRecord {
  id              String   @id @default(uuid())
  userId          String   @unique
  status          String   // 'PENDING', 'APPROVED', 'REJECTED'
  applicantId     String?
  documentType    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlockchainTransaction {
  id              String   @id @default(uuid())
  txHash          String   @unique
  userId          String?  // Relates to User.walletAddress or AuthUser.id
  blockNumber     Int
  status          String
  type            String   @default("SWAP")
  fromChain       String?
  toChain         String?
  fromToken       String?
  toToken         String?
  fromAmount      String?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ── 🔍 INDEXACIÓN CÓSMICA: Estado de transacciones para reconciliación ultra-rápida
  @@index([userId])                          // Lookup de historial por usuario
  @@index([status, createdAt(sort: Desc)])   // Monitoreo de pendientes en tiempo real
  @@index([blockNumber(sort: Desc)])         // Lookup por bloque
}

// FIX: Session polyfill for JWT verification route fallback
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String   
  expiresAt    DateTime
  ipAddress    String?
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// SOVEREIGN WALLET & EXCHANGE STATE
// ─────────────────────────────────────────────────────────────────────────────

model ExchangeBalance {
  id        String   @id @default(uuid())
  userId    String
  asset     String
  free      Float    @default(0.0)
  locked    Float    @default(0.0)
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// SYSTEM TELEMETRY
// ─────────────────────────────────────────────────────────────────────────────

model Log {
  id        String   @id @default(uuid())
  level     String   @default("info")
  message   String
  source    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRIVACY & SESSION AUDITING LOGS
// ─────────────────────────────────────────────────────────────────────────────

model UserSessionLog {
  id          String   @id @default(uuid())
  userId      String?
  sessionId   String
  timestamp   DateTime @default(now())
  action      String   // "PAGE_VIEW", "WALLET_CONNECT", "TAB_CHANGE", "EXPORT"
  entityType  String?
  entityId    String?
  ipAddress   String?
  userAgent   String?
  deviceType  String?
  location    String?
  metadata    Json?
  
  @@index([userId, timestamp(sort: Desc)])
  @@index([action, timestamp(sort: Desc)])
  @@index([sessionId])
  @@index([timestamp(sort: Desc)])
}

model UserPrivacyProfile {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  logLevel               String   @default("MEDIUM") 
  dataSharing            Boolean  @default(true)
  sessionAutoLogout      String   @default("1h")     
  ipWhitelist            String[] @default([])
  twoFAEnabled           Boolean  @default(false)
  sovereignVisibility    String   @default("Public") 
  exportEncryption       Boolean  @default(false)
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// AKASHIC COSMIC FORGE
// ─────────────────────────────────────────────────────────────────────────────

model CosmicEntity {
  id              String   @id @default(uuid())
  seedHash        String   @unique          // SHA-256 del evento whale origen
  whaleEventId    String?                   // FK a GlobalWhaleEvent
  tier            String                    // NARWHAL | KRAKEN | LEVIATHAN | MEGALODON
  amountUSD       Float
  chain           String
  generatorType   String                    // COSMIC_ART | LIVING_MUSIC | AUTO_CONTRACT | WORLD_SIM | BIOTECH_DNA | HIVE_AGENT | RECURSIVE_SUBFORGE
  status          String   @default("DORMANT") // DORMANT | ACTIVE | HIBERNATING | EXTINCT | MERGED
  artMetadata     Json?                     // { prompt, style, colorSeed, shaderParams }
  musicMetadata   Json?                     // { bpm, scale, waveform, key }
  biotechMetadata Json?                     // { dnaSequence, traits }
  worldSimMetadata Json?                    // { populationSeed, resources, entropy, gridSize }
  agentMetadata   Json?                     // { observerMode, targetChains, maxSlippageThreshold }
  contractAddress String?                   // Solo si se deployó un CosmicSoulERC1155
  hiveEnergyAtBirth Float  @default(0)
  evolutionCount  Int      @default(0)
  parentEntityId  String?                   // Para sub-forges recursivos
  beneficiaryAddr String?                   // Dead Man's Switch legado
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([tier, amountUSD(sort: Desc)])
  @@index([chain, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// FINTECH & GAMIFICATION (Unleashed Models)
// ─────────────────────────────────────────────────────────────────────────────

model VirtualCard {
  id              String   @id @default(uuid())
  userId          String   @unique
  cardNumber      String   @unique // Encrypted or masked
  expiryMonth     Int
  expiryYear      Int
  cvv             String   // Encrypted
  cardStatus      String   @default("ACTIVE") // ACTIVE, FROZEN, REVOKED
  balance         Float    @default(0)
  kycStatus       String   @default("PENDING") // PENDING, VERIFIED, FAILED
  providerId      String?  // e.g. Striga/Stripe issuing ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model GamificationRecord {
  id              String   @id @default(uuid())
  userId          String   @unique
  totalXp         Int      @default(0)
  level           Int      @default(1)
  currentTier     String   @default("INITIATE")
  achievements    String[] @default([])
  lastEventDate   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SOVEREIGN FORUM
// ─────────────────────────────────────────────────────────────────────────────

model ForumCategory {
  id          String       @id @default(uuid())
  slug        String       @unique
  name        String
  description String?      @db.Text
  color       String       @default("#888888")
  orderIndex  Int          @default(0)
  topics      ForumTopic[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ForumTag {
  id          String       @id @default(uuid())
  name        String       @unique
  topics      ForumTopic[] @relation("TopicTags")
}

model ForumTopic {
  id          String       @id @default(uuid())
  title       String
  content     String       @db.Text
  categoryId  String
  authorId    String
  views       Int          @default(0)
  isPinned    Boolean      @default(false)
  isLocked    Boolean      @default(false)
  
  category    ForumCategory @relation(fields: [categoryId], references: [id])
  author      User          @relation(fields: [authorId], references: [id])
  posts       ForumPost[]
  tags        ForumTag[]    @relation("TopicTags")
  likes       ForumLike[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
}

model ForumPost {
  id          String       @id @default(uuid())
  content     String       @db.Text
  topicId     String
  authorId    String
  replyToId   String?      // Optional: if replying to a specific post
  isSolution  Boolean      @default(false)

  topic       ForumTopic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id])
  replyTo     ForumPost?   @relation("Replies", fields: [replyToId], references: [id])
  replies     ForumPost[]  @relation("Replies")
  likes       ForumLike[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([topicId, createdAt(sort: Asc)])
}

model ForumLike {
  id          String       @id @default(uuid())
  userId      String
  topicId     String?
  postId      String?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic       ForumTopic?  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  post        ForumPost?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())

  @@unique([userId, topicId])
  @@unique([userId, postId])
}

model ForumNotification {
  id          String       @id @default(uuid())
  userId      String
  type        String       // "REPLY", "MENTION", "LIKE"
  actorId     String       // Who triggered it
  topicId     String?
  postId      String?
  isRead      Boolean      @default(false)
  
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor       User         @relation("ActorNotifications", fields: [actorId], references: [id])
  
  createdAt   DateTime     @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
}
