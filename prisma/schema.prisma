  protocol       String
  count          Int      @default(0)
  gasSpentUsd    Float    @default(0)
  latestActivity DateTime @default(now())

  @@index([walletId, protocol])
}

// ----------------------------------------------------------------------------
// 8. DARK POOL & GLOBAL INTELLIGENCE (PHASE 6)
// ----------------------------------------------------------------------------

model GlobalWhaleEvent {
  id          String   @id @default(cuid())
  hash        String
  logIndex    Int
  wallet      String
  token       String
  amount      String
  usdValue    Decimal  @db.Decimal(18, 2)
  action      String   @default("TRANSFER")
  tier        String   @default("INSTITUTIONAL")
  dex         String   @default("Mainnet Transfer")
  timestamp   DateTime @default(now())
  blockNumber BigInt

  @@unique([hash, logIndex])
  @@index([timestamp])
  @@index([usdValue])
}

model BlockScanTracker {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., "whale_radar_mainnet"
  lastBlock String // String to support BigInt values
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ----------------------------------------------------------------------------
// WHALE ALERT CORPORATION — API MARKETPLACE
// ----------------------------------------------------------------------------

model ApiSubscription {
  id     String @id @default(cuid())
  userId String
  tier   String // starter | pro | institutional
  status String @default("active") // active | past_due | canceled | disputed | suspended

  stripeSubscriptionId String @unique
  stripeCustomerId     String
  price                Float // USD per month

  // API Key — never stored raw, always SHA-256 hashed
  keyHash   String @unique
  keyPrefix String // First 16 chars for display (wac_live_XXXXXXX)

  // Plan limits
  dailyRequestLimit Int @default(10000) // -1 = unlimited
  whaleThresholdUsd Int @default(500000)
  maxApiKeys        Int @default(1)

  // Access window
  currentPeriodEnd DateTime?
  gracePeriodEnd   DateTime?

  // Security & Evidence
  purchaseIp       String    @default("")
  purchaseCountry  String    @default("")
  suspendedAt      DateTime?
  suspensionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Security & Delivery (Institutional/Pro)
  webhookUrl  String?
  ipWhitelist String[] @default([])
  hmacSecret  String? // For signing requests

  usageLogs   ApiUsageLog[]
  webhookLogs ApiWebhookLog[]

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
}

model ApiUsageLog {
  id             String          @id @default(cuid())
  subscriptionId String
  subscription   ApiSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  endpoint   String
  ip         String
  statusCode Int

  createdAt DateTime @default(now())

  @@index([subscriptionId, createdAt])
  @@index([createdAt])
}

model ApiPurchaseIntent {
  id              String   @id @default(cuid())
  clerkUserId     String
  planId          String
  stripeSessionId String   @unique
  ip              String
  country         String
  userAgent       String   @db.Text
  isSuspiciousIp  Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([clerkUserId])
  @@index([createdAt])
}

model ApiWebhookLog {
  id             String          @id @default(cuid())
  subscriptionId String
  subscription   ApiSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  url          String
  payload      Json
  responseCode Int?
  responseBody String? @db.Text
  error        String?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
}

// ============================================================================
// MODERNO: INSTITUTIONAL DASHBOARD EXTENSIONS (PORTED)
// ============================================================================

model Project {
  id          String       @id @default(uuid())
  userId      String?
  user        User?        @relation(fields: [userId], references: [walletAddress], onDelete: Cascade)
  name        String
  description String?
  status      String       @default("DRAFT")
  liquidity   Float        @default(0.0)
  oracle      String       @default("UMAOvl")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deployments Deployment[]

  // [PHASE 1] Real-Time Operational Metrics
  cpuUsage Float @default(0.0)
  ramUsage Float @default(0.0)
  uptime   Int   @default(0)
  logs     Log[]

  // [PHASE 3] Segmented Intelligence Routing
  trackedAsset String @default("ALL") // ETH | BTC | USDT | BNB | ALL
  dexFilter    String @default("ALL") // Uniswap | Binance | ALL

  @@index([userId])
}

model Deployment {
  id        String   @id @default(uuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  action    String
  status    String   @default("PENDING")
  txHash    String?
  createdAt DateTime @default(now())

  @@index([projectId])
}

model Variable {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [walletAddress], onDelete: Cascade)
  key         String
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

model Log {
  id      String @id @default(uuid())
  message String
  level   String @default("INFO")
  source  String @default("SYSTEM")

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}
