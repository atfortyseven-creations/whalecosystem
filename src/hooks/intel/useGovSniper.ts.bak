import { useMemo, useState, useEffect } from 'react';
import { analyticsService } from '@/lib/blockchain/AnalyticsService';

export interface Proposal {
    id: string;
    dao: string;
    title: string;
    timeLeftHours: number;
    userVoted: boolean;
    urgency: string;
}

export function useGovSniper() {
    const [proposals, setProposals] = useState<Proposal[]>([]);
    const [isLoading, setIsLoading] = useState(true);

    useEffect(() => {
        const fetchGov = async () => {
            try {
                const liveProposals = await analyticsService.getLiveGovProposals();
                setPools(liveProposals);
            } catch (e) {
                console.error('[useGovSniper] Governance synchronization failed');
            } finally {
                setIsLoading(false);
            }
        };
        fetchGov();
    }, []);

    const criticalProposals = useMemo(() => {
        return proposals
            .filter(p => p.timeLeftHours < 24 && !p.userVoted)
            .sort((a, b) => a.timeLeftHours - b.timeLeftHours);
    }, [proposals]);

    return {
        criticalProposals,
        allProposals: proposals,
        actionRequiredCount: criticalProposals.length,
        isLoading
    };
}
