{
  "name": "whale-alert-pro",
  "version": "3.0.2",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"npm run worker:scanner\"",
    "build": "echo 'LEGENDARY_BUILD_777' && prisma generate && prisma db push --accept-data-loss && cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:railway": "echo 'LEGENDARY_BUILD_777' && prisma generate && prisma db push --accept-data-loss && cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:contracts": "npx hardhat compile",
    "deploy:deadman": "npx hardhat run scripts/deploy-deadman-switch.js --network polygonAmoy",
    "deploy:deadman:mainnet": "npx hardhat run scripts/deploy-deadman-switch.js --network polygon",
    "build:extension": "node scripts/extension-build.js",
    "start": "next start",
    "start:prod": "npx prisma generate && npx prisma db push --accept-data-loss && cross-env NODE_OPTIONS=\"--max-old-space-size=2048\" npx next start -p ${PORT:-3000} -H 0.0.0.0",
    "start:gateway": "npx tsx services/gateway/server.ts",
    "start:scanner": "npx tsx services/scanner/index.ts",
    "start:alerts": "npx tsx scripts/alert-worker.ts",
    "start:solana": "npx tsx scripts/solana-worker.ts",
    "start:mesh": "npx tsx scripts/sovereign-mesh.ts",
    "start:all": "npx prisma db push --accept-data-loss && pm2-runtime start ecosystem.config.json",
    "lint": "next lint",
    "audit": "slither . --print human-summary",
    "audit:prepare": "slither . --print human-summary --exclude-dependencies --solc-remaps \"@openzeppelin=node_modules/@openzeppelin\"",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:status": "prisma migrate status",
    "check-migration": "ts-node scripts/check-migration-status.ts",
    "db:push": "prisma db push",
    "db:push:prod": "prisma db push --accept-data-loss",
    "db:seed": "prisma db seed",
    "worker": "npx tsx scripts/whale-worker.ts",
    "whale:start": "pm2 start ecosystem.config.json",
    "whale:stop": "pm2 stop whale-monitor",
    "whale:restart": "pm2 restart whale-monitor",
    "whale:logs": "pm2 logs whale-monitor",
    "whale:status": "pm2 status whale-monitor",
    "whale:keepalive": "bash scripts/keep-whale-alive.sh",
    "worker:scanner": "npx tsx scripts/whale-worker.ts",
    "worker:telegram": "npx tsx scripts/telegram-worker.ts",
    "worker:alerts": "npx tsx scripts/alert-worker.ts",
    "workers:start": "concurrently \"npm run worker:scanner\" \"npm run worker:telegram\" \"npm run worker:alerts\"",
    "deploy:sovereign": "npx hardhat run scripts/deploy-sovereign.ts --network base",
    "deploy:sovereign:testnet": "npx hardhat run scripts/deploy-sovereign.ts --network baseGoerli",
    "deploy:sovereign:local": "npx hardhat run scripts/deploy-sovereign.ts --network localhost",
    "test:contracts": "npx hardhat test --network hardhat",
    "test:deadman": "npx hardhat test test/WhaleDeadmanSwitch.test.ts --network hardhat",
    "test:timelock": "npx hardhat test test/HumanTimeLock.test.ts --network hardhat",
    "test:gas": "REPORT_GAS=true npx hardhat test --network hardhat",
    "k8s:apply": "kubectl apply -f k8s/",
    "k8s:delete": "kubectl delete -f k8s/",
    "k8s:status": "kubectl get all -n whale-alert",
    "helm:install": "helm install whale-alert k8s/helm --namespace whale-alert --create-namespace",
    "helm:upgrade": "helm upgrade whale-alert k8s/helm --namespace whale-alert --reuse-values",
    "helm:uninstall": "helm uninstall whale-alert --namespace whale-alert"
  },
  "engines": {
    "node": ">=20.0.0"
  },
