  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "echo 'LEGENDARY_BUILD_777' && npm run build:contracts && npx prisma db push --accept-data-loss && prisma generate && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" next build",
    "build:railway": "echo 'LEGENDARY_BUILD_777' && npm run build:contracts && npx prisma db push --accept-data-loss && prisma generate && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" next build",
    "build:contracts": "hardhat compile",
    "build:extension": "node scripts/extension-build.js",
    "start": "npx tsx scripts/production-cluster.ts",
    "start:gateway": "npx tsx services/gateway/server.ts",
    "start:scanner": "npx tsx services/scanner/index.ts",
    "start:all": "npm run start & npm run start:gateway & npm run start:scanner & npm run start:alerts",
    "start:alerts": "npx tsx scripts/alert-worker.ts",
    "lint": "next lint",
    "audit": "slither . --print human-summary",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:status": "prisma migrate status",
    "check-migration": "ts-node scripts/check-migration-status.ts",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "worker": "npx tsx scripts/whale-worker.ts",
    "whale:start": "pm2 start ecosystem.config.json",
    "whale:stop": "pm2 stop whale-monitor",
    "whale:restart": "pm2 restart whale-monitor",
    "whale:logs": "pm2 logs whale-monitor",
    "whale:status": "pm2 status whale-monitor",
    "whale:keepalive": "bash scripts/keep-whale-alive.sh"
  },
