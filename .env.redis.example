# Add these variables to your .env.local file for backend optimizations

# ===== UPSTASH REDIS (for caching and rate limiting) =====
# Sign up at https://upstash.com and create a Redis database
# Then copy the REST URL and TOKEN from the dashboard

UPSTASH_REDIS_REST_URL=your_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# Note: Without these, the app will still work but caching and rate limiting will be disabled
# For development, you can leave these empty. For production, they are highly recommended.
