{
  "apps": [
    {
      "name": "sovereign-web",
      "script": "/app/node_modules/.bin/next",
      "args": "start -p 3000 -H 0.0.0.0",
      "cwd": "/app",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "PORT": "3000",
        "HOSTNAME": "0.0.0.0",
        "NODE_OPTIONS": "--max-old-space-size=2048"
      },
      "max_memory_restart": "1800M",
      "restart_delay": 2000,
      "exp_backoff_restart_delay": 100,
      "max_restarts": 20,
      "watch": false,
      "error_file": "/dev/stderr",
      "out_file": "/dev/stdout"
    },
    {
      "name": "sovereign-worker",
      "script": "/app/node_modules/.bin/tsx",
      "args": "/app/scripts/whale-worker.ts",
      "cwd": "/app",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "WHALE_WORKER_FORCE_START": "true"
      },
      "max_memory_restart": "800M",
      "restart_delay": 5000,
      "exp_backoff_restart_delay": 200,
      "max_restarts": 15,
      "watch": false,
      "error_file": "/dev/stderr",
      "out_file": "/dev/stdout"
    }
  ]
}
