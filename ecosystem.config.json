{
  "apps": [
    {
      "name": "sovereign-web",
      "script": "node_modules/next/dist/bin/next",
      "args": "start",
      "cwd": "/app",
      "interpreter": "node",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "HOSTNAME": "0.0.0.0",
        "NODE_OPTIONS": "--max-old-space-size=2048"
      },
      "max_memory_restart": "1800M",
      "restart_delay": 3000,
      "exp_backoff_restart_delay": 200,
      "max_restarts": 15,
      "watch": false,
      "kill_timeout": 5000,
      "wait_ready": false,
      "autorestart": true
    }
  ]
}
