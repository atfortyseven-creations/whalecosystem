{
  "apps": [
    {
      "name": "sovereign-web",
      "script": "server.js",
      "cwd": "/app",
      "interpreter": "node",
      "instances": "max",
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "production",
        "HOSTNAME": "0.0.0.0",
        "NODE_OPTIONS": "--max-old-space-size=4096"
      },
      "max_memory_restart": "3800M",
      "restart_delay": 3000,
      "exp_backoff_restart_delay": 200,
      "max_restarts": 15,
      "watch": false,
      "kill_timeout": 5000,
      "wait_ready": false,
      "autorestart": true
    }
  ]
}
