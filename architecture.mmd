%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '36px', 'fontFamily': 'Inter', 'primaryColor': '#ffffff' }}}%%
graph TB
    classDef default fill:#f9f9f9,stroke:#333,stroke-width:4px,color:#000,font-family:Inter,font-size:36px;
    classDef title fill:#ffffff,stroke:none,color:#111,font-size:100px,font-weight:bold;
    classDef l1 fill:#e3f2fd,stroke:#1565c0,stroke-width:6px,color:#000,font-size:42px,font-weight:bold;
    classDef l2 fill:#e8f5e9,stroke:#2e7d32,stroke-width:6px,color:#000,font-size:42px,font-weight:bold;
    classDef l3 fill:#fff3e0,stroke:#ef6c00,stroke-width:6px,color:#000,font-size:42px,font-weight:bold;
    classDef l4 fill:#f3e5f5,stroke:#6a1b9a,stroke-width:6px,color:#000,font-size:42px,font-weight:bold;
    classDef highlight fill:#ffebee,stroke:#c62828,stroke-width:8px,color:#000,font-size:46px,font-weight:bold;
    classDef nodebox fill:#ffffff,stroke:#555,stroke-width:4px,color:#000,font-size:36px;
    classDef tech fill:#eceff1,stroke:#607d8b,stroke-width:4px,color:#222,font-size:32px,font-style:italic;

    Title[/"WHALE NETWORK <br/> MASTER HYBRID ARCHITECTURE (PC & MOBILE)"/]:::title

    subgraph L_EVM [1. EVM BASE & PROTOCOL LAYER]
        direction LR
        RPC[RPC Nodes<br/>Alchemy / Infura / Public]:::l1
        Mem[Mempool Streams<br/>Pending Txs]:::nodebox
        Blk[Confirmed Blocks<br/>ETH / Base]:::nodebox
        RPProvider[ResilientProvider<br/>Circuit Breaker Fail-over]:::tech
        Moralis[Moralis Deep Indexing<br/>Historical Data]:::tech
        
        RPC --> RPProvider
        RPProvider --> Mem
        RPProvider --> Blk
        Moralis -.-> Blk
    end

    subgraph L_ENGINE [2. BACKGROUND WHALE ENGINE]
        direction TB
        EVMScan[EVM Whale Scanner]:::l3
        BTCScan[BTC Mempool Scanner]:::l3
        TGAlert[Telegram Alert Bot]:::tech
        AlchMon[Alchemy Monitor<br/>Elite Addresses]:::nodebox
        
        EVMScan --> TGAlert
        BTCScan --> TGAlert
    end

    subgraph L_DATA [3. STATE & PERSISTENCE LAYER]
        direction LR
        Prisma[(PostgreSQL<br/>Prisma ORM<br/>User State)]:::nodebox
        Mongo[(MongoDB<br/>Mongoose<br/>Polymarket Indices)]:::nodebox
        Neo[(Neo4j Graph<br/>Whale Relations)]:::nodebox
        Redis[(Redis / Upstash<br/>PubSub & Cache)]:::nodebox
    end

    subgraph L_AZTEC [4. PRIVATE AZTEC LAYER SHIELDED]
        direction TB
        Pxe[PXE<br/>Private Execution Env]:::l4
        Noir[Noir Circuits<br/>Aztec.nr]:::nodebox
        Azt[Aztec Account<br/>ECDSA Contracts]:::nodebox
        L2[Aztec L2<br/>Shielded Pool]:::highlight
        
        Pxe -->|ACIR Compilation| Noir
        Noir -->|UltraHonk Backend| L2
        L2 -->|Settlement| Azt
    end

    subgraph L_ZK [5. ZK SECURITY & IDENTITY LAYER]
        direction LR
        WorldID[WorldID Integration<br/>Sybil Resistance]:::nodebox
        Cir[circomlibjs<br/>ZK-SNARK Circuits]:::tech
        Hnd[QR Handshake<br/>E2EE Protocol]:::highlight
        
        WorldID --> Cir
    end

    subgraph L_VAULT [6. SYSTEM DESKTOP VAULT PC HYBRID CORE]
        direction TB
        Daemon[SystemVault_RUN.bat<br/>Local Daemon]:::l2
        Wrk[Whale Worker Nodes<br/>Data Crunching]:::nodebox
        Intel[Intelligence Service<br/>AI Forensics & Heatmaps]:::tech
        Gateway[Celestial Gateway<br/>Node.js + WebSockets<br/>Port 3000]:::highlight
        
        Daemon --> Wrk
        Wrk --> Intel
        Intel --> Gateway
    end

    subgraph L_CLIENT [7. CLIENT TERMINAL & MOBILE USER INTERFACE]
        direction LR
        Nxt[Next.js 15 Desktop Web<br/>LiquidPrism UI]:::l1
        Pwa[iOS / Android PWA<br/>Offline Ready]:::l1
    end

    Mem --> EVMScan
    Blk --> EVMScan
    RPProvider --> AlchMon
    
    EVMScan -->|Store Tx Data| Prisma
    EVMScan -->|Graph Relations| Neo
    EVMScan -->|Publish vitals.tx.new| Redis
    AlchMon --> Redis
    
    Prisma <--> Daemon
    Redis <--> Gateway
    Mongo <--> Intel
    Neo <--> Intel
    
    Daemon -->|Locally Hosted Hub| Cir
    Daemon -->|E2EE Tunnel| Hnd
    
    Gateway == Sub-100ms WebSocket ==> Nxt
    Gateway == Sub-100ms WebSocket ==> Pwa
    
    Nxt -->|Zero Knowledge Verified| Cir
    Pwa -.->|QR Handshake Sync| Hnd
    Hnd --> Daemon
    
    Nxt -->|aztec.js client-side proofs| Pxe
    Pwa -->|aztec.js client-side proofs| Pxe
    
    class L_EVM,L_ENGINE,L_DATA,L_AZTEC,L_ZK,L_VAULT,L_CLIENT default;
